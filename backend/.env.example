# Copy to .env and adjust. All variables are prefixed with CVE2BF_.

# --- NVD data source ---
# Optional NVD API key raises the rate limit (get one at nvd.nist.gov).
# CVE2BF_NVD_API_KEY=your-key-here
# Serve only bundled fixtures, never hit the network (air-gapped / demo):
CVE2BF_OFFLINE_MODE=false

# --- vLLM inference server ---
# Point this at your running `vllm serve` OpenAI-compatible endpoint.
CVE2BF_VLLM_BASE_URL=http://10.116.34.124:8117/v1
CVE2BF_VLLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
CVE2BF_VLLM_API_KEY=EMPTY
# If vLLM is unreachable, fall back to the deterministic extractor:
CVE2BF_VLLM_FALLBACK_ENABLED=true

# --- HTTP ---
# CVE2BF_CORS_ORIGINS=["http://localhost:5173"]
